generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Classroom {
  id            String   @id
  title         String?
  status        String   @default("active")
  stage         Json
  scenes        Json
  outlines      Json
  userId        String?
  ltiContextId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
